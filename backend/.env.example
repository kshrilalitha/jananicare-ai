# JananiCare Backend Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=production

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/jananicare

# Security
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# External Services
AI_API_URL=https://your-ai-api.render.com
FAST2SMS_API_KEY=your_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=https://jananicare.vercel.app
